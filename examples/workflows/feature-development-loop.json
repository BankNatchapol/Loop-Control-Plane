{
  "id": "workflow-feature-development-loop",
  "projectId": "project-loopboard",
  "name": "Feature Development Loop",
  "description": "End-to-end feature workflow: human writes a brief, Spec Kit generates and clarifies artifacts, AO implements per task with CI loops and PR review, then the feature branch is tested, reviewed, and merged.",
  "version": 1,
  "nodes": [
    {
      "id": "node-human-input",
      "workflowId": "workflow-feature-development-loop",
      "type": "human-input",
      "name": "Human Input",
      "guidance": "Write the feature brief or PRD. Describe what you want built — scope, goals, any constraints. This becomes the source of truth for Spec Kit.",
      "mode": "human",
      "position": { "x": 0, "y": 120 },
      "inputArtifacts": [],
      "outputArtifacts": [
        { "name": "feature-brief", "path": "specs/{feature}/PRD.md", "required": true }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-spec-kit-actions",
      "workflowId": "workflow-feature-development-loop",
      "type": "spec-kit-actions",
      "name": "Spec Kit Actions",
      "guidance": "Spec Kit reads the PRD and generates spec.md, plan.md, tasks.md, an artifact consistency analysis, and a quality checklist. Review the outputs before the Clarify step.",
      "mode": "semi",
      "position": { "x": 260, "y": 120 },
      "inputArtifacts": [
        { "name": "feature-brief", "path": "specs/{feature}/PRD.md", "required": true }
      ],
      "outputArtifacts": [
        { "name": "spec",      "path": "specs/{feature}/spec.md",      "required": true },
        { "name": "plan",      "path": "specs/{feature}/plan.md",      "required": true },
        { "name": "tasks",     "path": "specs/{feature}/tasks.md",     "required": true },
        { "name": "checklist", "path": "specs/{feature}/checklist.md", "required": false }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {
        "executor": {
          "backend": "spec-kit",
          "args": ["spec", "plan", "tasks", "analyze", "checklist"],
          "timeoutMs": 300000
        }
      },
      "currentState": "idle"
    },
    {
      "id": "node-spec-kit-clarify",
      "workflowId": "workflow-feature-development-loop",
      "type": "spec-kit-clarify",
      "name": "Spec Kit Clarify",
      "guidance": "Run `speckit.clarify` in your terminal. The AI will surface underspecified areas and ask questions. Answer them to tighten the spec. If the spec changes substantially, loop back to regenerate plan and tasks. Approve here when the spec is solid.",
      "mode": "human",
      "position": { "x": 520, "y": 120 },
      "inputArtifacts": [
        { "name": "spec", "path": "specs/{feature}/spec.md", "required": true }
      ],
      "outputArtifacts": [
        { "name": "clarified-spec", "path": "specs/{feature}/spec.md", "required": true }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-human-review",
      "workflowId": "workflow-feature-development-loop",
      "type": "human-review",
      "name": "Human Review",
      "guidance": "Final human sign-off before implementation begins. Review spec.md, plan.md, tasks.md, and the checklist. Approve only when you are confident the scope is correct — this gates AO spawning agents.",
      "mode": "human",
      "position": { "x": 780, "y": 120 },
      "inputArtifacts": [
        { "name": "spec",      "path": "specs/{feature}/spec.md",      "required": true },
        { "name": "plan",      "path": "specs/{feature}/plan.md",      "required": true },
        { "name": "tasks",     "path": "specs/{feature}/tasks.md",     "required": true },
        { "name": "checklist", "path": "specs/{feature}/checklist.md", "required": false }
      ],
      "outputArtifacts": [
        {
          "name": "approved-artifacts",
          "path": "loopboard://feature/{feature}/approvals",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-import-tasks",
      "workflowId": "workflow-feature-development-loop",
      "type": "import-tasks",
      "name": "Import Tasks",
      "mode": "semi",
      "position": { "x": 1040, "y": 120 },
      "inputArtifacts": [
        { "name": "tasks", "path": "specs/{feature}/tasks.md", "required": true }
      ],
      "outputArtifacts": [
        {
          "name": "loopboard-tasks",
          "path": "loopboard://feature/{feature}/tasks",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "low",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-create-github-issues",
      "workflowId": "workflow-feature-development-loop",
      "type": "create-github-issues",
      "name": "Create GitHub Issues",
      "mode": "semi",
      "position": { "x": 1300, "y": 120 },
      "inputArtifacts": [
        {
          "name": "loopboard-tasks",
          "path": "loopboard://feature/{feature}/tasks",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "github-issues",
          "path": "https://github.com/{repository}/issues",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-agent-orchestrator-implement",
      "workflowId": "workflow-feature-development-loop",
      "type": "agent-orchestrator-implement",
      "name": "AO Implement",
      "guidance": "AO spawns one agent per GitHub issue. Each agent works in its own worktree: implements, self-fixes CI, opens a per-task PR, then loops on review comments until approved. Install PR Agent as a GitHub Action so it reviews PRs automatically — AO picks up its comments and addresses them. The workflow waits here until all per-task PRs are merged into the feature branch.",
      "mode": "auto",
      "position": { "x": 1560, "y": 120 },
      "inputArtifacts": [
        {
          "name": "github-issues",
          "path": "https://github.com/{repository}/issues",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "requireApproval": false,
      "maxRetries": 2,
      "riskPolicy": "medium",
      "config": {
        "executor": {
          "backend": "agent-orchestrator",
          "timeoutMs": 1800000
        }
      },
      "currentState": "idle"
    },
    {
      "id": "node-run-tests",
      "workflowId": "workflow-feature-development-loop",
      "type": "run-tests",
      "name": "Run Tests",
      "guidance": "Runs the project test suite against the feature branch after all per-task PRs are merged. Provides independent verification beyond AO's internal CI loop.",
      "mode": "auto",
      "position": { "x": 1820, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "test-report",
          "path": "loopboard://runs/{run}/test-report",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 2,
      "riskPolicy": "low",
      "config": {
        "executor": {
          "command": "npm test",
          "timeoutMs": 600000
        }
      },
      "currentState": "idle"
    },
    {
      "id": "node-ai-review",
      "workflowId": "workflow-feature-development-loop",
      "type": "ai-review",
      "name": "AI Review",
      "guidance": "AI reads the diff and the test report, then either approves (→ Open PR) or flags changes needed (→ Manual Claude Code Edit). Change the Agent field in the sidebar to pick the review backend.",
      "mode": "auto",
      "position": { "x": 2080, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        },
        {
          "name": "test-report",
          "path": "loopboard://runs/{run}/test-report",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "review-notes",
          "path": "loopboard://runs/{run}/review-notes",
          "required": true
        }
      ],
      "requireApproval": false,
      "maxRetries": 0,
      "riskPolicy": "low",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-manual-claude-code-edit",
      "workflowId": "workflow-feature-development-loop",
      "type": "manual-claude-code-edit",
      "name": "Manual Claude Code Edit",
      "guidance": "AI Review flagged issues that need human attention. Open the review-notes artifact and apply fixes in Claude Code. Approve when the branch is ready to re-test.",
      "mode": "human",
      "position": { "x": 2080, "y": 320 },
      "inputArtifacts": [
        {
          "name": "review-notes",
          "path": "loopboard://runs/{run}/review-notes",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "manual-patch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": { "optional": true },
      "currentState": "idle"
    },
    {
      "id": "node-open-pr",
      "workflowId": "workflow-feature-development-loop",
      "type": "open-pr",
      "name": "Open PR",
      "guidance": "Opens the final pull request for the feature branch into main. This is the merge-to-main PR — separate from AO's per-task PRs that targeted the feature branch.",
      "mode": "semi",
      "position": { "x": 2340, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "pull-request",
          "path": "https://github.com/{repository}/pulls",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-merge",
      "workflowId": "workflow-feature-development-loop",
      "type": "merge",
      "name": "Merge",
      "guidance": "Final human gate. Review the PR, confirm CI is green, then approve here to merge the feature branch into main.",
      "mode": "human",
      "position": { "x": 2600, "y": 120 },
      "inputArtifacts": [
        {
          "name": "pull-request",
          "path": "https://github.com/{repository}/pulls",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "merged-branch",
          "path": "git://{repository}/{defaultBranch}",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    }
  ],
  "edges": [
    {
      "id": "edge-node-human-input-to-node-spec-kit-actions",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-human-input",
      "targetNodeId": "node-spec-kit-actions",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-spec-kit-actions-to-node-spec-kit-clarify",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-spec-kit-actions",
      "targetNodeId": "node-spec-kit-clarify",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-spec-kit-clarify-to-node-human-review",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-spec-kit-clarify",
      "targetNodeId": "node-human-review",
      "label": "approved",
      "condition": {}
    },
    {
      "id": "edge-node-spec-kit-clarify-to-node-spec-kit-actions",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-spec-kit-clarify",
      "targetNodeId": "node-spec-kit-actions",
      "label": "needs more",
      "dashed": true,
      "condition": {}
    },
    {
      "id": "edge-node-human-review-to-node-import-tasks",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-human-review",
      "targetNodeId": "node-import-tasks",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-import-tasks-to-node-create-github-issues",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-import-tasks",
      "targetNodeId": "node-create-github-issues",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-create-github-issues-to-node-agent-orchestrator-implement",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-create-github-issues",
      "targetNodeId": "node-agent-orchestrator-implement",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-agent-orchestrator-implement-to-node-run-tests",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-agent-orchestrator-implement",
      "targetNodeId": "node-run-tests",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-run-tests-to-node-ai-review",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-run-tests",
      "targetNodeId": "node-ai-review",
      "label": "next",
      "condition": {}
    },
    {
      "id": "edge-node-ai-review-to-node-open-pr",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-ai-review",
      "targetNodeId": "node-open-pr",
      "label": "approved",
      "condition": {}
    },
    {
      "id": "edge-node-ai-review-to-node-manual-claude-code-edit",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-ai-review",
      "targetNodeId": "node-manual-claude-code-edit",
      "label": "needs changes",
      "dashed": true,
      "condition": {}
    },
    {
      "id": "edge-node-manual-claude-code-edit-to-node-run-tests",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-manual-claude-code-edit",
      "targetNodeId": "node-run-tests",
      "label": "retry",
      "dashed": true,
      "condition": {}
    },
    {
      "id": "edge-node-open-pr-to-node-merge",
      "workflowId": "workflow-feature-development-loop",
      "sourceNodeId": "node-open-pr",
      "targetNodeId": "node-merge",
      "label": "next",
      "condition": {}
    }
  ],
  "config": {
    "defaultFeatureId": "feature-kanban-control-plane",
    "pauseOnHumanNodes": true,
    "redactSecretsInLogs": true
  }
}
