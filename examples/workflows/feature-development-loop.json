{
  "id": "workflow-feature-development-loop",
  "projectId": "project-loopboard",
  "name": "Feature Development Loop",
  "description": "PRD-aligned feature workflow from human intake through Spec Kit artifacts, task import, AI implementation, review, pull request, and merge.",
  "version": 1,
  "nodes": [
    {
      "id": "node-human-input",
      "workflowId": "workflow-feature-development-loop",
      "type": "human-input",
      "name": "Human Input",
      "mode": "human",
      "position": { "x": 0, "y": 120 },
      "inputArtifacts": [],
      "outputArtifacts": [
        { "name": "feature-brief", "path": "specs/{feature}/PRD.md", "required": true }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-spec-kit-actions",
      "workflowId": "workflow-feature-development-loop",
      "type": "spec-kit-actions",
      "name": "Spec Kit Actions",
      "mode": "semi",
      "position": { "x": 260, "y": 120 },
      "inputArtifacts": [
        { "name": "feature-brief", "path": "specs/{feature}/PRD.md", "required": true }
      ],
      "outputArtifacts": [
        { "name": "spec", "path": "specs/{feature}/spec.md", "required": true },
        { "name": "plan", "path": "specs/{feature}/plan.md", "required": true },
        { "name": "tasks", "path": "specs/{feature}/tasks.md", "required": true }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {
        "executor": {
          "backend": "codex",
          "args": ["spec", "plan", "tasks"],
          "timeoutMs": 300000
        }
      },
      "currentState": "idle"
    },
    {
      "id": "node-human-review",
      "workflowId": "workflow-feature-development-loop",
      "type": "human-review",
      "name": "Human Review",
      "mode": "human",
      "position": { "x": 520, "y": 120 },
      "inputArtifacts": [
        { "name": "spec", "path": "specs/{feature}/spec.md", "required": true },
        { "name": "plan", "path": "specs/{feature}/plan.md", "required": true },
        { "name": "tasks", "path": "specs/{feature}/tasks.md", "required": true }
      ],
      "outputArtifacts": [
        {
          "name": "approved-artifacts",
          "path": "loopboard://feature/{feature}/approvals",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-import-tasks",
      "workflowId": "workflow-feature-development-loop",
      "type": "import-tasks",
      "name": "Import Tasks",
      "mode": "semi",
      "position": { "x": 780, "y": 120 },
      "inputArtifacts": [
        { "name": "tasks", "path": "specs/{feature}/tasks.md", "required": true }
      ],
      "outputArtifacts": [
        {
          "name": "loopboard-tasks",
          "path": "loopboard://feature/{feature}/tasks",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "low",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-create-github-issues",
      "workflowId": "workflow-feature-development-loop",
      "type": "create-github-issues",
      "name": "Create GitHub Issues",
      "mode": "semi",
      "position": { "x": 1040, "y": 120 },
      "inputArtifacts": [
        {
          "name": "loopboard-tasks",
          "path": "loopboard://feature/{feature}/tasks",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "github-issues",
          "path": "https://github.com/{repository}/issues",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-agent-orchestrator-implement",
      "workflowId": "workflow-feature-development-loop",
      "type": "agent-orchestrator-implement",
      "name": "Agent Orchestrator Implement",
      "guidance": "AO spawns one agent per GitHub issue. Each agent works in its own worktree and branch, implements the feature, self-fixes CI failures, opens a PR, then loops on review comments until the PR is approved. To automate the review step, install PR Agent as a GitHub Action on the repo — it posts review comments automatically when AO opens a PR, which AO then addresses. The workflow pauses only when human judgment is required.",
      "mode": "semi",
      "position": { "x": 1300, "y": 120 },
      "inputArtifacts": [
        {
          "name": "github-issues",
          "path": "https://github.com/{repository}/issues",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 2,
      "riskPolicy": "medium",
      "config": {
        "executor": {
          "backend": "agent-orchestrator"
        }
      },
      "currentState": "idle"
    },
    {
      "id": "node-run-tests",
      "workflowId": "workflow-feature-development-loop",
      "type": "run-tests",
      "name": "Run Tests",
      "mode": "semi",
      "position": { "x": 1560, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "test-report",
          "path": "loopboard://runs/{run}/test-report",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 2,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-ai-review",
      "workflowId": "workflow-feature-development-loop",
      "type": "ai-review",
      "name": "AI Review",
      "mode": "semi",
      "position": { "x": 1820, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        },
        {
          "name": "test-report",
          "path": "loopboard://runs/{run}/test-report",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "review-notes",
          "path": "loopboard://runs/{run}/review-notes",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-manual-claude-code-edit",
      "workflowId": "workflow-feature-development-loop",
      "type": "manual-claude-code-edit",
      "name": "Manual Claude Code Edit",
      "mode": "human",
      "position": { "x": 1820, "y": 320 },
      "inputArtifacts": [
        {
          "name": "review-notes",
          "path": "loopboard://runs/{run}/review-notes",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "manual-patch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": { "optional": true },
      "currentState": "idle"
    },
    {
      "id": "node-open-pr",
      "workflowId": "workflow-feature-development-loop",
      "type": "open-pr",
      "name": "Open PR",
      "mode": "semi",
      "position": { "x": 2080, "y": 120 },
      "inputArtifacts": [
        {
          "name": "implementation-branch",
          "path": "git://{repository}/{branch}",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "pull-request",
          "path": "https://github.com/{repository}/pulls",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 1,
      "riskPolicy": "medium",
      "config": {},
      "currentState": "idle"
    },
    {
      "id": "node-merge",
      "workflowId": "workflow-feature-development-loop",
      "type": "merge",
      "name": "Merge",
      "mode": "human",
      "position": { "x": 2340, "y": 120 },
      "inputArtifacts": [
        {
          "name": "pull-request",
          "path": "https://github.com/{repository}/pulls",
          "required": true
        }
      ],
      "outputArtifacts": [
        {
          "name": "merged-branch",
          "path": "git://{repository}/{defaultBranch}",
          "required": true
        }
      ],
      "requireApproval": true,
      "maxRetries": 0,
      "riskPolicy": "manual-only",
      "config": {},
      "currentState": "idle"
    }
  ],
  "edges": [
    {
      "id": "edge-node-human-input-to-node-spec-kit-actions",
      "workflowId": "workflow-feature-development-loop",
